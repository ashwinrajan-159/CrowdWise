# CrowdWise web app — environment variables.
# Copy to `.env` for local use (and never commit your real .env).

# PredictHQ API token for live event data. Without it, the app falls back to the
# bundled sample event calendar (events_cache.json) and still works fully.
# Get one at https://www.predicthq.com/  ->  Account  ->  API Tokens
PREDICTHQ_TOKEN=

# How often (minutes) the in-process scheduler re-scrapes + re-forecasts.
REFRESH_MINUTES=60

# City to fetch events for.
CITY=Bengaluru

# Port the server binds to (Render/Railway inject this automatically).
PORT=8000

# Set to 0 to disable the in-process refresh scheduler (e.g. for tests).
ENABLE_SCHEDULER=1
